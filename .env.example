# Copy to .env (which is git-ignored) before running `docker compose up` / `make dev`.
# Local Supabase CLI prints these via `supabase status` after `supabase start`.
# The defaults below are the well-known local-CLI placeholders — replace if
# your `supabase status` output differs.

SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Where the app is reachable from a browser. Used for OAuth redirect_to and
# password-reset email links. Defaults to http://localhost:8501 if unset.
# In prod, set this to your Streamlit Cloud URL (e.g. https://you-app.streamlit.app).
APP_SITE_URL=http://localhost:8501

# Used only by scripts/migrate_sqlite_to_supabase.py (direct Postgres connection,
# bypasses RLS). Service-role / superuser-level access.
SUPABASE_DB_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# Optional: needed only if you enable GitHub OAuth in supabase/config.toml
# (Local CLI testing only -- prod credentials live in the Supabase dashboard.)
# SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
